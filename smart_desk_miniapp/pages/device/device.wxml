<view class="page">
  <view class="header-mini">
    <text class="header-mini-title">🪑 设备控制</text>
    <text class="header-mini-sub">实时监控与智能控制</text>
  </view>

  <view class="content">
    <view class="card animate-fade-in-up delay-1">
      <view class="card-header">
        <view class="device-status-header">
          <text class="card-title">设备状态</text>
          <view class="device-badge {{device.status === '在线' ? 'badge-online' : 'badge-offline'}}">
            <view class="mini-dot {{device.status === '在线' ? 'mini-dot-online' : 'mini-dot-offline'}}"></view>
            <text>{{device.status || '--'}}</text>
          </view>
        </view>
      </view>
      <view class="device-main-info">
        <view class="device-icon-area">
          <text class="device-big-icon">🪑</text>
        </view>
        <view class="device-details">
          <view class="detail-row">
            <text class="detail-label">型号</text>
            <text class="detail-value">智能学习桌 Pro</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">设备ID</text>
            <text class="detail-value">{{device.id || '--'}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="card animate-fade-in-up delay-2">
      <view class="card-header">
        <text class="card-icon">📊</text>
        <text class="card-title">运行参数</text>
      </view>
      <view class="params">
        <view class="param-item">
          <view class="param-header">
            <text class="param-label">桌面高度</text>
            <text class="param-value">{{device.height || '--'}} cm</text>
          </view>
          <view class="param-bar">
            <view class="param-fill height-fill" style="width: {{((device.height || 0) / 100) * 100}}%"></view>
          </view>
        </view>
        <view class="param-item">
          <view class="param-header">
            <text class="param-label">灯光亮度</text>
            <text class="param-value">{{device.light || '--'}}%</text>
          </view>
          <view class="param-bar">
            <view class="param-fill light-fill" style="width: {{device.light || 0}}%"></view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
