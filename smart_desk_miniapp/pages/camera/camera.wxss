.page {
  min-height: 100vh;
}

.header-mini {
  background: linear-gradient(135deg, #0f0c29, #302b63);
  padding: 40rpx;
}

.header-mini-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.header-mini-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 8rpx;
  display: block;
}

.content {
  padding: 30rpx;
}

.camera-frame {
  background: #000;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.3);
  border: 2rpx solid #333;
}

.camera-image {
  width: 100%;
  height: 420rpx;
  display: block;
}

.camera-fallback {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #0f0c29;
  gap: 12rpx;
}

.fallback-icon {
  font-size: 72rpx;
}

.fallback-text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
}

.fallback-hint {
  font-size: 24rpx;
  color: #888;
}

.camera-rec {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(0,0,0,0.6);
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
}

.rec-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ff3b30;
  animation: pulse 1.2s ease infinite;
}

.rec-text {
  font-size: 20rpx;
  font-weight: 700;
  color: #ff3b30;
  letter-spacing: 2rpx;
}

.camera-label {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background: rgba(0,0,0,0.6);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  color: #00ff88;
  font-family: monospace;
}

.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.status-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.status-icon {
  font-size: 28rpx;
}

.status-text {
  font-size: 26rpx;
  color: #636e72;
}

.live-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #b2bec3;
}

.live-active {
  background: #00b894;
  animation: pulse 2s ease infinite;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.1);
}

.card-upload {
  border-left: 6rpx solid #667eea;
}

.card-upload:active {
  opacity: 0.7;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.card-icon {
  font-size: 32rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #636e72;
  flex: 1;
}

.card-badge {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.card-badge.idle {
  background: #f0f2f5;
  color: #b2bec3;
}

.card-badge.loading {
  background: #fff7e6;
  color: #e6a23c;
}

.card-badge.success {
  background: #e8f8f5;
  color: #00b894;
}

.upload-hint {
  font-size: 24rpx;
  color: #b2bec3;
  margin-left: 56rpx;
}

.info-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
  border-bottom: 1rpx solid #f0f2f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #636e72;
}

.info-value {
  font-size: 26rpx;
  font-weight: 500;
  color: #2d3436;
}

.tip-text {
  font-size: 24rpx;
  color: #636e72;
  line-height: 1.8;
}
