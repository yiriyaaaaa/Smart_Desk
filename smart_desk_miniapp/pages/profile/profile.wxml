<view class="page">
  <view class="profile-header">
    <view class="avatar">
      <text class="avatar-text">{{user.name ? user.name[0] : '?'}}</text>
    </view>
    <text class="user-name">{{user.name || '用户'}}</text>
    <text class="user-id">ID: {{user.id || '--'}}</text>
  </view>

  <view class="content">
    <view class="card animate-fade-in-up delay-1">
      <view class="card-header">
        <text class="card-icon">👤</text>
        <text class="card-title">个人信息</text>
      </view>
      <view class="info-list">
        <view class="info-row">
          <text class="info-label">姓名</text>
          <text class="info-value">{{user.name || '--'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">班级</text>
          <text class="info-value">{{user.class || '--'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">设备ID</text>
          <text class="info-value">{{user.id || '--'}}</text>
        </view>
      </view>
    </view>

    <view class="menu-card animate-fade-in-up delay-2">
      <view class="menu-item">
        <text class="menu-icon">⚙️</text>
        <text class="menu-text">设置</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item">
        <text class="menu-icon">📊</text>
        <text class="menu-text">数据统计</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item">
        <text class="menu-icon">💬</text>
        <text class="menu-text">帮助与反馈</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>
</view>
