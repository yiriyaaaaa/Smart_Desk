<view class="page">
  <view class="header-mini">
    <text class="header-mini-title">🚗 智能小车</text>
    <text class="header-mini-sub">实时位姿与远程控制</text>
  </view>

  <view class="content">
    <view class="card animate-fade-in-up delay-1">
      <view class="card-header">
        <view class="device-status-header">
          <text class="card-title">设备状态</text>
          <view class="device-badge {{online ? 'badge-online' : 'badge-offline'}}">
            <view class="mini-dot {{online ? 'mini-dot-online' : 'mini-dot-offline'}}"></view>
            <text>{{online ? '在线' : '离线'}}</text>
          </view>
        </view>
      </view>
      <view class="device-main-info">
        <view class="device-icon-area">
          <text class="device-big-icon">🚗</text>
        </view>
        <view class="device-details">
          <view class="detail-row">
            <text class="detail-label">设备ID</text>
            <text class="detail-value">{{car.carId || '--'}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">工作状态</text>
            <text class="detail-value state-tag">{{stateText}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">定位质量</text>
            <text class="detail-value">{{locQuality}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">最后更新</text>
            <text class="detail-value">{{formattedTime}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="card animate-fade-in-up delay-2">
      <view class="card-header">
        <text class="card-icon">📍</text>
        <text class="card-title">位姿信息</text>
      </view>
      <view class="params">
        <view class="param-row">
          <text class="param-label">坐标 X</text>
          <text class="param-value">{{poseX}}</text>
        </view>
        <view class="param-row">
          <text class="param-label">坐标 Y</text>
          <text class="param-value">{{poseY}}</text>
        </view>
        <view class="param-row">
          <text class="param-label">朝向 Yaw</text>
          <text class="param-value">{{poseYaw}}</text>
        </view>
        <view class="param-row" wx:if="{{goalValid}}">
          <text class="param-label">目标点</text>
          <text class="param-value">({{goalX}}, {{goalY}})</text>
        </view>
      </view>
    </view>

    <view class="card animate-fade-in-up delay-3">
      <view class="card-header">
        <text class="card-icon">🎮</text>
        <text class="card-title">控制</text>
      </view>
      <view class="control-grid">
        <view class="ctrl-btn" bindtap="goTo">
          <text class="ctrl-icon">📍</text>
          <text class="ctrl-label">前往坐标</text>
        </view>
        <view class="ctrl-btn" bindtap="stop">
          <text class="ctrl-icon">⏹️</text>
          <text class="ctrl-label">停止</text>
        </view>
        <view class="ctrl-btn" bindtap="pause">
          <text class="ctrl-icon">⏸️</text>
          <text class="ctrl-label">暂停</text>
        </view>
        <view class="ctrl-btn" bindtap="resume">
          <text class="ctrl-icon">▶️</text>
          <text class="ctrl-label">恢复</text>
        </view>
      </view>
    </view>
  </view>
</view>
