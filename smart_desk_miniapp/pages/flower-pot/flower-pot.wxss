.page { min-height: 100vh; }
.header-mini { background: linear-gradient(135deg, #11998e, #38ef7d); padding: 40rpx; }
.header-mini-title { font-size: 36rpx; font-weight: 600; color: #fff; }
.header-mini-sub { font-size: 24rpx; color: rgba(255,255,255,0.7); margin-top: 8rpx; display: block; }
.content { padding: 30rpx; }
.card { background: #fff; border-radius: 24rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 20rpx rgba(17,153,142,0.1); }
.card-header { margin-bottom: 24rpx; display: flex; align-items: center; gap: 12rpx; }
.card-title { font-size: 28rpx; font-weight: 500; color: #636e72; }
.card-icon { font-size: 32rpx; }
.device-main-info { display: flex; gap: 32rpx; align-items: center; }
.device-icon-area { width: 120rpx; height: 120rpx; border-radius: 24rpx; background: #e8faf5; display: flex; align-items: center; justify-content: center; }
.device-big-icon { font-size: 56rpx; }
.device-details { flex: 1; display: flex; flex-direction: column; gap: 16rpx; }
.detail-row { display: flex; justify-content: space-between; align-items: center; }
.detail-label { font-size: 26rpx; color: #b2bec3; }
.detail-value { font-size: 26rpx; font-weight: 500; color: #2d3436; }
.ok-text { color: #00b894; }
.warn-text { color: #e17055; }
.params { display: flex; flex-direction: column; gap: 28rpx; }
.param-item { display: flex; flex-direction: column; gap: 12rpx; }
.param-header { display: flex; justify-content: space-between; }
.param-label { font-size: 26rpx; color: #636e72; }
.param-value { font-size: 26rpx; font-weight: 600; color: #2d3436; }
.param-bar { height: 12rpx; background: #f0f2f5; border-radius: 10rpx; overflow: hidden; }
.param-fill { height: 100%; border-radius: 10rpx; transition: width 0.8s ease; }
.soil-fill { background: linear-gradient(90deg, #11998e, #38ef7d); }
.temp-fill { background: linear-gradient(90deg, #f093fb, #f5576c); }
.hum-fill { background: linear-gradient(90deg, #4facfe, #00f2fe); }
.light-fill { background: linear-gradient(90deg, #fdcb6e, #f39c12); }
.status-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.status-item { display: flex; align-items: center; gap: 12rpx; padding: 20rpx; border-radius: 12rpx; font-size: 26rpx; }
.status-on { background: #e8f8f5; color: #00b894; }
.status-off { background: #f5f5f5; color: #b2bec3; }
.status-icon { font-size: 24rpx; }
.control-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.ctrl-btn { display: flex; flex-direction: column; align-items: center; gap: 8rpx; padding: 28rpx; background: #f8f9fc; border-radius: 16rpx; }
.ctrl-btn:active { background: #eef0f5; }
.ctrl-disabled { opacity: 0.5; }
.ctrl-icon { font-size: 40rpx; }
.ctrl-label { font-size: 24rpx; color: #636e72; }
