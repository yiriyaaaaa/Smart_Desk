.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  overflow: hidden;
}

.header::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
}

.header-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  z-index: 1;
}

.greeting {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

.header-icon {
  font-size: 80rpx;
  z-index: 1;
}

.content {
  padding: 30rpx 30rpx 0;
  margin-top: -20rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.1);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.card-icon {
  font-size: 32rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #636e72;
}

.study-body {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  padding: 16rpx 0;
}

.study-number {
  font-size: 72rpx;
  font-weight: 700;
  color: #667eea;
  line-height: 1;
}

.study-unit {
  font-size: 28rpx;
  color: #b2bec3;
}

.card-footer {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f2f5;
}

.footer-text {
  font-size: 24rpx;
  color: #b2bec3;
}

.row {
  display: flex;
  gap: 24rpx;
}

.card-half {
  flex: 1;
  width: 50%;
}

.posture-body {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.status-badge {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.badge-good {
  background: #e8f8f5;
  color: #00b894;
}

.badge-warn {
  background: #fef3e2;
  color: #e17055;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.dot-good {
  background: #00b894;
  animation: pulse 2s ease infinite;
}

.dot-warn {
  background: #e17055;
  animation: pulse 2s ease infinite;
}

.evaluate-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3436;
}

.device-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.device-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.device-label {
  font-size: 26rpx;
  color: #636e72;
}

.device-value {
  font-size: 26rpx;
  font-weight: 500;
  color: #2d3436;
}

.device-status-indicator {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.online {
  color: #00b894;
}

.offline {
  color: #e17055;
}

.status-dot-indicator {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

.dot-online {
  background: #00b894;
  animation: pulse 2s ease infinite;
}

.dot-offline {
  background: #e17055;
}

.light-bar {
  width: 160rpx;
  height: 12rpx;
  background: #f0f2f5;
  border-radius: 10rpx;
  overflow: hidden;
}

.light-fill {
  height: 100%;
  background: linear-gradient(90deg, #fdcb6e, #f39c12);
  border-radius: 10rpx;
  transition: width 0.6s ease;
}

.card-clickable {
  border-left: 6rpx solid #00b894;
}

.card-clickable:active {
  opacity: 0.7;
  transform: scale(0.98);
}

.card-arrow {
  margin-left: auto;
  font-size: 36rpx;
  color: #b2bec3;
  font-weight: 300;
}

.camera-preview {
  padding: 8rpx 0;
}

.camera-hint {
  font-size: 26rpx;
  color: #00b894;
}
